PORT=3001

# AirLabs API key — free tier provides 1,000 route lookups/month (used before FlightAware)
# Register at https://airlabs.co
AIRLABS_API_KEY=your_airlabs_api_key_here

# FlightAware AeroAPI key — fallback when AirLabs quota is exhausted or flight not found
# Register at https://www.flightaware.com/aeroapi/
FLIGHTAWARE_API_KEY=your_flightaware_api_key_here

# Optional: restrict access to a secret token (recommended for remote hosting)
# ACCESS_TOKEN=your_secret_token_here
